APP_NAME=CodeDNA API
APP_VERSION=0.1.0
APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/codna
REDIS_URL=redis://redis:6379/0
REPOSITORY_WORKSPACE_PATH=/var/lib/codna/repositories
REPOSITORY_FILE_MAX_BYTES=10485760
REPOSITORY_FILE_DISCOVERY_LIMIT=5000
OPENAI_API_KEY=your-openai-api-key
GOOGLE_API_KEY=your-google-ai-studio-api-key
EMBEDDING_PROVIDER=google
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=64
ANSWER_PROVIDER=openai
ANSWER_MODEL=gpt-5.4-mini
ANSWER_MAX_CONTEXT_CHUNKS=8
ANSWER_MAX_RELATED_CHUNKS=4
ANSWER_MAX_CONTEXT_CHARACTERS=18000
ANSWER_MAX_OUTPUT_TOKENS=1600
ANSWER_BUDGET_USD=4.00
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:8000/api/v1/auth/github/callback
GITHUB_AUTHORIZE_URL=https://github.com/login/oauth/authorize
GITHUB_TOKEN_URL=https://github.com/login/oauth/access_token
GITHUB_USER_URL=https://api.github.com/user
GITHUB_API_URL=https://api.github.com
GITHUB_REPOSITORIES_URL=https://api.github.com/user/repos
GITHUB_SCOPE=read:user user:email
FRONTEND_URL=http://localhost:3000
JWT_SECRET=your-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
OAUTH_STATE_EXPIRE_MINUTES=10
